{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"],
    "paths": {
      "@cdk8s-charts/utils": ["packages/utils/src/index.ts"],
      "@cdk8s-charts/litellm": ["packages/charts/litellm/src/index.ts"],
      "@cdk8s-charts/hindsight": ["packages/charts/hindsight/src/index.ts"],
      "@cdk8s-charts/hindsight-litellm": ["packages/recipes/hindsight-litellm/src/index.ts"]
    }
  }
}
