# Copy to .env and fill in real values:
#   cp .env.example .env

# LiteLLM admin master key (generate: openssl rand -hex 16)
LITELLM_MASTER_KEY=

# OpenAI API key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Virtual key for Hindsight -> LiteLLM auth (generate: openssl rand -hex 16, prefix with sk-)
HINDSIGHT_LLM_KEY=
